# Example environment variables for kbot-installer providers.
# They must be exported in your shell profile (~/.bash_profile, ~/.zprofile):
#   export NEXUS_USERNAME=mon-username
#   export NEXUS_PASSWORD=mon-password
#
# Without 'export', variables are visible to echo but not to uv run / Python.
# Verify with: env | grep NEXUS

# Bitbucket Configuration
export BITBUCKET_USERNAME=mon-username
export BITBUCKET_APP_PASSWORD=mon-app-password
export BITBUCKET_WORKSPACE=mon-workspace

# Nexus Configuration
export NEXUS_USERNAME=mon-username
export NEXUS_PASSWORD=mon-password

# GitHub Configuration
export GITHUB_USERNAME=mon-username
export GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Note: For SSH authentication, ensure your keys are configured in
# ~/.ssh/id_rsa and ~/.ssh/id_rsa.pub
