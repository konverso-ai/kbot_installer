{
  "providers": {
    "nexus": {
      "kwargs": {
        "domain": "nexus.konverso.ai",
        "repository": "kbot_raw"
      },
      "env_vars": ["NEXUS_USERNAME", "NEXUS_PASSWORD"],
      "auth_type": "http_auth",
      "auth_params": {
        "username": "NEXUS_USERNAME",
        "password": "NEXUS_PASSWORD"
      },
      "branches": ["master", "dev"]
    },
    "github": {
      "kwargs": {
        "account_name": "konverso-ai"
      },
      "env_vars": ["GITHUB_TOKEN"],
      "auth_type": "pygit_auth",
      "auth_params": {
        "username": "git",
        "password": "GITHUB_TOKEN"
      },
      "branches": ["main", "dev"]
    },
    "bitbucket": {
      "kwargs": {
        "account_name": "konversoai"
      },
      "env_vars": ["BITBUCKET_USERNAME", "BITBUCKET_APP_PASSWORD"],
      "auth_type": "pygit_auth",
      "auth_params": {
        "username": "BITBUCKET_USERNAME",
        "password": "BITBUCKET_APP_PASSWORD"
      },
      "branches": ["master", "dev"]
    }
  }
}
